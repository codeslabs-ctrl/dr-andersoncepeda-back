# Copiar como config.env y rellenar con tus valores.
# Este archivo no debe contener datos reales (no se sube al repo).

# Server Configuration
PORT=3006
NODE_ENV=production

# Supabase (si aplica)
SUPABASE_URL=
SUPABASE_ANON_KEY=

# PostgreSQL - OBLIGATORIO
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=tu_base_datos
POSTGRES_USER=tu_usuario
POSTGRES_PASSWORD=tu_contraseña_segura
POSTGRES_SSL=false
POSTGRES_CONNECTION_TIMEOUT=30000
POSTGRES_QUERY_TIMEOUT=30000

# API Configuration
API_URL=https://tu-dominio.com
API_VERSION=v1
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS (origen del frontend en producción)
CORS_ORIGIN=https://tu-dominio.com
CORS_CREDENTIALS=true

# JWT - Usar claves largas y aleatorias
JWT_SECRET=genera-una-clave-secreta-muy-larga
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# Security
ENCRYPTION_KEY=clave-encriptacion-32-chars!!
API_KEY=api-key-interno
SALT_ROUNDS=12

# Rate Limiting
RATE_LIMIT_AUTH_MAX=100
RATE_LIMIT_AUTH_WINDOW=900000
RATE_LIMIT_INFORME_MAX=3
RATE_LIMIT_INFORME_WINDOW=60000
RATE_LIMIT_EMAIL_MAX=10
RATE_LIMIT_EMAIL_WINDOW=300000

# Email (SMTP o Gmail app password)
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_SERVICE=gmail
EMAIL_HOST=
EMAIL_PORT=
EMAIL_SECURE=
EMAIL_FROM=Tu App <tu-email@dominio.com>

# Clínica
CLINICA_ALIAS=alias
CLINICA_NOMBRE=Nombre de la Clínica
CLINICA_DESCRIPCION=Descripción
CLINICA_DIRECCION=Dirección
SISTEMA_NOMBRE=Sistema de Gestión Médica

# Frontend URL (para links en emails, etc.)
FRONTEND_URL=https://tu-dominio.com

# Logo (ruta relativa al backend)
LOGO_PATH=./assets/logos/clinica/logo.png

# Integraciones externas (opcional, separar por comas si hay varias)
# EXTERNAL_PATIENT_APP_API_KEYS=
# EXTERNAL_N8N_API_KEYS=
