# Copiar como config.dev.env y rellenar con tus valores para desarrollo local.
# Este archivo no debe contener datos reales (no se sube al repo).

# Server Configuration
PORT=3006
NODE_ENV=development

# Supabase (si aplica)
SUPABASE_URL=
SUPABASE_ANON_KEY=

# PostgreSQL - OBLIGATORIO (puede ser local o remoto)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=tu_base_datos
POSTGRES_USER=tu_usuario
POSTGRES_PASSWORD=tu_contraseña
POSTGRES_SSL=false
POSTGRES_CONNECTION_TIMEOUT=5000
POSTGRES_QUERY_TIMEOUT=30000

# API Configuration
API_VERSION=v1
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS (desarrollo: origen del frontend, normalmente localhost:4200)
CORS_ORIGIN=http://localhost:4200
CORS_CREDENTIALS=true

# JWT (desarrollo: puede ser una clave de ejemplo)
JWT_SECRET=clave-secreta-desarrollo
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# Security
ENCRYPTION_KEY=clave-encriptacion-dev
API_KEY=api-key-dev
SALT_ROUNDS=12

# Rate Limiting
RATE_LIMIT_AUTH_MAX=100
RATE_LIMIT_AUTH_WINDOW=900000
RATE_LIMIT_INFORME_MAX=3
RATE_LIMIT_INFORME_WINDOW=60000
RATE_LIMIT_EMAIL_MAX=10
RATE_LIMIT_EMAIL_WINDOW=300000

# Email
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_SERVICE=gmail
EMAIL_HOST=
EMAIL_PORT=
EMAIL_SECURE=
EMAIL_FROM=Dev <dev@ejemplo.com>

# Clínica (desarrollo)
CLINICA_ALIAS=dev
CLINICA_NOMBRE=Mi Clínica (Dev)
CLINICA_DESCRIPCION=Entorno de desarrollo
SISTEMA_NOMBRE=Sistema de Gestión Médica

# Frontend (desarrollo)
FRONTEND_URL=http://localhost:4200

# Logo
LOGO_PATH=./assets/logos/clinica/logo.png

# Integraciones externas (opcional)
# EXTERNAL_PATIENT_APP_API_KEYS=
# EXTERNAL_N8N_API_KEYS=
